# ═══════════════════════════════════════════════════════════════
# MLOps Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════

# ── Anthropic (LLM powering the agent) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Azure DevOps ──────────────────────────────────────────────────
AZURE_DEVOPS_ORG=your-org-name
AZURE_DEVOPS_PROJECT=your-project-name
AZURE_DEVOPS_REPO=your-repo-name
AZURE_DEVOPS_PAT=your-personal-access-token

# ── Azure Service Principal ───────────────────────────────────────
# Create with: az ad sp create-for-rbac --name mlops-agent --role contributor
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Azure ML Workspace ────────────────────────────────────────────
AML_WORKSPACE_NAME=your-aml-workspace
AML_RESOURCE_GROUP=your-resource-group

# ── Azure Container Registry ──────────────────────────────────────
ACR_REGISTRY=yourregistry.azurecr.io
ACR_IMAGE_NAME=mlops-env

# ── Memory / Conversation Storage ────────────────────────────────
# SQLite .db file where all conversation history is persisted locally.
# Every thread_id gets its own isolated history in this file.
# Change to an absolute path if needed (e.g. C:/Users/Suriya/mlops_memory.db)
MEMORY_DB_PATH=mlops_agent_memory.db

# ── Drift Thresholds (0.0 - 1.0) ─────────────────────────────────
DATA_DRIFT_THRESHOLD=0.15
PREDICTION_DRIFT_THRESHOLD=0.10
CONCEPT_DRIFT_THRESHOLD=0.05
